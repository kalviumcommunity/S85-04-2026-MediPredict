    "def parse_medical_date(date_string):\n",
    "    \"\"\"\n",
    "    Parse date from various medical system formats.\n",
    "    \n",
    "    Supports:\n",
    "    - ISO format: 2024-03-15\n",
    "    - US format: 03/15/2024\n",
    "    - Legacy format: 15-MAR-2024 (Epic EHR legacy export)\n",
    "    \"\"\"\n",
    "    from datetime import datetime\n",
    "    \n",
    "    # Try ISO format first (most common in modern systems)\n",
    "    try:\n",
    "        return datetime.strptime(date_string, \"%Y-%m-%d\")\n",
    "    except ValueError:\n",
    "        pass\n",
    "    \n",
    "    # Try US format\n",
    "    try:\n",
    "        return datetime.strptime(date_string, \"%m/%d/%Y\")\n",
    "    except ValueError:\n",
    "        pass\n",
    "    \n",
    "    # Legacy Epic format - required for historical data migration\n",
    "    # TODO: Remove this after migration complete (target: 2024-Q4)\n",
    "    try:\n",
    "        return datetime.strptime(date_string, \"%d-%b-%Y\")\n",
    "    except ValueError:\n",
    "        raise ValueError(f\"Unable to parse date: {date_string}\")\n",
    "\n",
