    "def calculate_medication_dosage(patient_weight_kg, patient_age_years, medication_name):\n",
    "    \"\"\"\n",
    "    Calculate appropriate medication dosage for a patient.\n",
    "    \n",
    "    This function uses weight-based dosing with age adjustments.\n",
    "    Children (<12 years) receive 50% of adult dose.\n",
    "    Seniors (>65 years) receive 75% of adult dose.\n",
    "    \n",
    "    Args:\n",
    "        patient_weight_kg (float): Patient weight in kilograms\n",
    "        patient_age_years (int): Patient age in years\n",
    "        medication_name (str): Name of the medication\n",
    "    \n",
    "    Returns:\n",
    "        dict: Dosage information containing:\n",
    "            - 'dosage_mg' (float): Calculated dosage in milligrams\n",
    "            - 'adjustment_factor' (float): Applied age adjustment\n",
    "            - 'adult_equivalent' (float): Dosage without adjustment\n",
    "    \n",
    "    Raises:\n",
    "        ValueError: If weight or age is negative\n",
    "    \n",
    "    Example:\n",
    "        >>> result = calculate_medication_dosage(70, 45, 'Aspirin')\n",
    "        >>> print(result['dosage_mg'])\n",
    "        700.0\n",
    "    \"\"\"\n",
    "    if patient_weight_kg < 0 or patient_age_years < 0:\n",
    "        raise ValueError(\"Weight and age must be non-negative\")\n",
    "    \n",
    "    base_dosage_per_kg = 10  # mg per kg\n",
    "    adult_dosage = patient_weight_kg * base_dosage_per_kg\n",
    "    \n",
    "    # Apply age-based adjustments\n",
    "    if patient_age_years < 12:\n",
    "        adjustment_factor = 0.5  # Pediatric dosing\n",
    "    elif patient_age_years > 65:\n",
    "        adjustment_factor = 0.75  # Geriatric dosing\n",
    "    else:\n",
    "        adjustment_factor = 1.0  # Adult dosing\n",
    "    \n",
    "    adjusted_dosage = adult_dosage * adjustment_factor\n",
    "    \n",
    "    return {\n",
    "        'dosage_mg': round(adjusted_dosage, 1),\n",
    "        'adjustment_factor': adjustment_factor,\n",
    "        'adult_equivalent': round(adult_dosage, 1)\n",
    "    }\n",
    "\n",
