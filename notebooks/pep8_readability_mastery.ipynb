    "# When Comments Are Actually Useful\n",
    "print(\"\\n=== WHEN COMMENTS ADD VALUE ===\")\n",
    "print()\n",
    "\n",
    "print(\"1️⃣ Explaining business logic or domain rules:\")\n",
    "\n",
    "def calculate_insurance_premium(age, smoker, bmi):\n",
    "    \"\"\"\n",
    "    Calculate insurance premium based on risk factors.\n",
    "    \n",
    "    Pricing model uses age-banded rates with modifiers:\n",
    "    - Base rate increases 5% per year after age 30\n",
    "    - Smoking adds flat $500/year surcharge\n",
    "    - BMI >30 adds 20% risk adjustment\n",
    "    \n",
    "    Model approved by actuarial team on 2024-01-15.\n",
    "    Ref: Insurance Pricing Policy v2.3, section 4.2\n",
    "    \"\"\"\n",
    "    base_rate = 1000\n",
    "    \n",
    "    # Age adjustment: 5% increase per year after 30\n",
    "    if age > 30:\n",
    "        age_adjustment = 1 + (age - 30) * 0.05\n",
    "        base_rate *= age_adjustment\n",
    "    \n",
    "    # Smoking surcharge per underwriting guidelines\n",
    "    if smoker:\n",
    "        base_rate += 500\n",
    "    \n",
    "    # BMI risk adjustment for obesity-related conditions\n",
    "    if bmi > 30:\n",
    "        base_rate *= 1.2\n",
    "    \n",
    "    return round(base_rate, 2)\n",
    "\n",
    "premium = calculate_insurance_premium(45, True, 32)\n",
    "print(f\"Premium for 45yo smoker with BMI 32: ${premium}\")\n",
