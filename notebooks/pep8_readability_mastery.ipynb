    "# Good vs Bad Comments - Side-by-Side\n",
    "print(\"=== GOOD vs BAD COMMENTS ===\")\n",
    "print()\n",
    "\n",
    "print(\"❌ BAD COMMENTS (What, not Why):\")\n",
    "print(\"\"\"\n",
    "# Get patient age\n",
    "patient_age = 45\n",
    "\n",
    "# Add 1 to age\n",
    "next_year_age = patient_age + 1\n",
    "\n",
    "# Check if age is greater than 65\n",
    "if next_year_age > 65:\n",
    "    # Set is_senior to True\n",
    "    is_senior = True  # This is a boolean\n",
    "\"\"\")\n",
    "\n",
    "print(\"Problems:\")\n",
    "print(\"  • Comments state the obvious\")\n",
    "print(\"  • No value added - just restate what code says\")\n",
    "print(\"  • Waste of space and reader's time\")\n",
    "print()\n",
    "\n",
    "print(\"✅ GOOD COMMENTS (Why, not What):\")\n",
    "print(\"\"\"\n",
    "# Age threshold for senior discount eligibility per hospital policy\n",
    "SENIOR_DISCOUNT_AGE_THRESHOLD = 65\n",
    "\n",
    "patient_age = 45\n",
    "next_year_age = patient_age + 1\n",
    "\n",
    "# Patient becomes eligible for senior discount next year\n",
    "if next_year_age > SENIOR_DISCOUNT_AGE_THRESHOLD:\n",
    "    is_senior_discount_eligible = True\n",
    "\"\"\")\n",
    "\n",
    "print(\"Improvements:\")\n",
    "print(\"  • Comments explain business reason and policy reference\")\n",
    "print(\"  • Clear what the number 65 represents\")\n",
    "print(\"  • Explains WHY we check this, not WHAT we're checking\")\n",
    "print()\n",
