   "source": [
    "# PEP 8 Naming Conventions - Comprehensive Examples\n",
    "print(\"=== PEP 8 NAMING CONVENTIONS ===\")\n",
    "print()\n",
    "\n",
    "print(\"1️⃣ VARIABLES: snake_case\")\n",
    "print(\"   Convention: lowercase with underscores\")\n",
    "print()\n",
    "\n",
    "# ❌ Bad variable names\n",
    "PatientAge = 45      # CamelCase - wrong for variables\n",
    "patientage = 45      # All lowercase - hard to read\n",
    "PA = 45              # Abbreviation - cryptic\n",
    "x = 45               # Single letter - meaningless\n",
    "patient_age_ = 45    # Trailing underscore - unnecessary\n",
    "\n",
    "# ✅ Good variable names (snake_case)\n",
    "patient_age = 45\n",
    "blood_pressure_systolic = 120\n",
    "heart_rate_bpm = 72\n",
    "is_smoker = False\n",
    "patient_name_first = \"Alice\"\n",
    "\n",
    "print(\"   ❌ Bad:  PatientAge, patientage, PA, x\")\n",
    "print(\"   ✅ Good: patient_age, blood_pressure_systolic, heart_rate_bpm\")\n",
    "print()\n",
    "\n",
    "print(\"2️⃣ FUNCTIONS: snake_case with verbs\")\n",
    "print(\"   Convention: lowercase with underscores, start with verb\")\n",
    "print()\n",
    "\n",
    "# ❌ Bad function names\n",
    "def calc():          # Abbreviation\n",
    "    pass\n",
    "\n",
    "def DataProcess():   # PascalCase - wrong for functions\n",
    "    pass\n",
    "\n",
    "def getData():       # camelCase - wrong for Python\n",
    "    pass\n",
    "\n",
    "def process():        # No verb - what are we processing?\n",
    "    pass\n",
    "\n",
    "# ✅ Good function names (snake_case with verbs)\n",
    "def calculate_bmi(weight, height):\n",
    "    \"\"\"Calculate BMI from weight and height.\"\"\"\n",
    "    return weight / (height ** 2)\n",
    "\n",
    "def get_patient_by_id(patient_id):\n",
    "    \"\"\"Retrieve patient record by ID.\"\"\"\n",
    "    pass\n",
    "\n",
    "def validate_patient_age(age):\n",
    "    \"\"\"Check if age is within valid range.\"\"\"\n",
    "    return 0 <= age <= 120\n",
    "\n",
    "def format_patient_name(first_name, last_name):\n",
    "    \"\"\"Format patient name with proper capitalization.\"\"\"\n",
    "    return f\"{first_name} {last_name}\".title()\n",
    "\n",
    "print(\"   ❌ Bad:  calc(), DataProcess(), getData(), process()\")\n",
    "print(\"   ✅ Good: calculate_bmi(), get_patient_by_id(), validate_patient_age()\")\n",
    "print()\n",
    "\n",
    "print(\"3️⃣ CONSTANTS: UPPER_SNAKE_CASE\")\n",
    "print(\"   Convention: ALL CAPS with underscores\")\n",
    "print()\n",
    "\n",
    "# ❌ Bad constant names\n",
    "max_patients = 100          # lowercase - looks like variable\n",
    "MaxPatients = 100           # PascalCase - wrong\n",
    "maxPatients = 100           # camelCase - wrong\n",
    "\n",
    "# ✅ Good constant names (UPPER_SNAKE_CASE)\n",
    "MAX_PATIENTS = 100\n",
    "DEFAULT_TIMEOUT_SECONDS = 30\n",
    "MINIMUM_AGE_YEARS = 0\n",
    "MAXIMUM_AGE_YEARS = 120\n",
    "BMI_UNDERWEIGHT_THRESHOLD = 18.5\n",
    "BMI_OVERWEIGHT_THRESHOLD = 25.0\n",
    "BMI_OBESE_THRESHOLD = 30.0\n",
    "\n",
    "print(\"   ❌ Bad:  max_patients, MaxPatients, maxPatients\")\n",
    "print(\"   ✅ Good: MAX_PATIENTS, DEFAULT_TIMEOUT_SECONDS, MINIMUM_AGE_YEARS\")\n",
    "print()\n",
    "\n",
    "print(\"4️⃣ PRIVATE/INTERNAL: _leading_underscore\")\n",
    "print(\"   Convention: single leading underscore indicates 'internal use'\")\n",
    "print()\n",
    "\n",
    "# Private/internal variables\n",
    "_internal_counter = 0\n",
    "_cached_results = {}\n",
    "\n",
    "# Private/internal functions\n",
    "def _validate_input_format(data):\n",
    "    \"\"\"Internal validation - not part of public API.\"\"\"\n",
    "    return isinstance(data, dict)\n",
    "\n",
    "def _calculate_intermediate_value(x, y):\n",
    "    \"\"\"Helper function - internal use only.\"\"\"\n",
    "    return (x + y) / 2\n",
    "\n",
    "print(\"   ✅ Good: _internal_counter, _cached_results, _validate_input_format()\")\n",
    "print(\"   Note: Leading underscore signals 'private/internal' to other developers\")"
   ]
  },
