    "# Complete Well-Structured Example\n",
    "print(\"\\n=== COMPLETE STRUCTURED EXAMPLE ===\")\n",
    "print(\"Patient Health Assessment System\")\n",
    "print()\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 1: CONSTANTS\n",
    "# =============================================================================\n",
    "\n",
    "HEALTH_THRESHOLDS = {\n",
    "    'bp': {'normal_sys': 120, 'normal_dia': 80, 'high_sys': 140, 'high_dia': 90},\n",
    "    'bmi': {'underweight': 18.5, 'normal': 25, 'overweight': 30},\n",
    "    'age': {'senior': 65, 'adult': 18, 'max': 120}\n",
    "}\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 2: HELPER FUNCTIONS (Low-level utilities)\n",
    "# =============================================================================\n",
    "\n",
    "def parse_blood_pressure(bp_string):\n",
    "    \"\"\"Parse blood pressure from string format 'systolic/diastolic'.\"\"\"\n",
    "    systolic, diastolic = map(int, bp_string.split('/'))\n",
    "    return systolic, diastolic\n",
    "\n",
    "def calculate_bmi(weight_kg, height_m):\n",
    "    \"\"\"Calculate BMI from weight (kg) and height (m).\"\"\"\n",
    "    return weight_kg / (height_m ** 2)\n",
    "\n",
    "def is_valid_age(age):\n",
    "    \"\"\"Check if age is within valid human range.\"\"\"\n",
    "    return 0 <= age <= HEALTH_THRESHOLDS['age']['max']\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 3: CLASSIFICATION FUNCTIONS (Business logic)\n",
    "# =============================================================================\n",
    "\n",
    "def classify_blood_pressure(systolic, diastolic):\n",
    "    \"\"\"Classify blood pressure level.\"\"\"\n",
    "    thresholds = HEALTH_THRESHOLDS['bp']\n",
    "    \n",
    "    if systolic >= thresholds['high_sys'] or diastolic >= thresholds['high_dia']:\n",
    "        return 'Hypertension'\n",
    "    elif systolic >= thresholds['normal_sys'] or diastolic >= thresholds['normal_dia']:\n",
    "        return 'Elevated'\n",
    "    else:\n",
    "        return 'Normal'\n",
    "\n",
    "def classify_bmi(bmi):\n",
    "    \"\"\"Classify BMI category.\"\"\"\n",
    "    thresholds = HEALTH_THRESHOLDS['bmi']\n",
    "    \n",
    "    if bmi < thresholds['underweight']:\n",
    "        return 'Underweight'\n",
    "    elif bmi < thresholds['normal']:\n",
    "        return 'Normal'\n",
    "    elif bmi < thresholds['overweight']:\n",
    "        return 'Overweight'\n",
    "    else:\n",
    "        return 'Obese'\n",
    "\n",
    "def classify_age_group(age):\n",
    "    \"\"\"Classify age into demographic group.\"\"\"\n",
    "    thresholds = HEALTH_THRESHOLDS['age']\n",
    "    \n",
    "    if age >= thresholds['senior']:\n",
    "        return 'Senior'\n",
    "    elif age >= thresholds['adult']:\n",
    "        return 'Adult'\n",
    "    else:\n",
    "        return 'Minor'\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 4: ASSESSMENT FUNCTIONS (High-level analysis)\n",
    "# =============================================================================\n",
    "\n",
    "def assess_patient_health(patient):\n",
    "    \"\"\"\n",
    "    Perform complete health assessment on a patient.\n",
    "    \n",
    "    Returns dictionary with all classifications and recommendations.\n",
    "    \"\"\"\n",
    "    systolic, diastolic = parse_blood_pressure(patient['bp'])\n",
    "    bmi = calculate_bmi(patient['weight_kg'], patient['height_m'])\n",
    "    \n",
    "    assessment = {\n",
    "        'patient_id': patient['id'],\n",
    "        'name': patient['name'],\n",
    "        'vitals': {\n",
    "            'bp': f\"{systolic}/{diastolic}\",\n",
    "            'bmi': round(bmi, 1),\n",
    "            'age': patient['age']\n",
    "        },\n",
    "        'classifications': {\n",
    "            'bp_class': classify_blood_pressure(systolic, diastolic),\n",
    "            'bmi_class': classify_bmi(bmi),\n",
    "            'age_group': classify_age_group(patient['age'])\n",
    "        },\n",
    "        'risk_factors': []\n",
    "    }\n",
    "    \n",
    "    # Identify risk factors\n",
    "    if assessment['classifications']['bp_class'] == 'Hypertension':\n",
    "        assessment['risk_factors'].append('High blood pressure')\n",
    "    if assessment['classifications']['bmi_class'] in ['Overweight', 'Obese']:\n",
    "        assessment['risk_factors'].append(assessment['classifications']['bmi_class'])\n",
    "    if patient.get('smoker', False):\n",
    "        assessment['risk_factors'].append('Smoking')\n",
    "    \n",
    "    # Generate recommendation\n",
    "    if len(assessment['risk_factors']) >= 2:\n",
    "        assessment['recommendation'] = 'Schedule comprehensive health review'\n",
    "    elif len(assessment['risk_factors']) == 1:\n",
    "        assessment['recommendation'] = 'Discuss risk factor with provider'\n",
    "    else:\n",
    "        assessment['recommendation'] = 'Continue routine monitoring'\n",
    "    \n",
    "    return assessment\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 5: REPORTING FUNCTIONS (Output generation)\n",
    "# =============================================================================\n",
    "\n",
    "def format_patient_summary(assessment):\n",
    "    \"\"\"Format patient assessment as readable summary.\"\"\"\n",
    "    lines = [\n",
    "        f\"\\n{assessment['name']} ({assessment['patient_id']})\",\n",
    "        f\"  Age: {assessment['vitals']['age']} ({assessment['classifications']['age_group']})\",\n",
    "        f\"  BMI: {assessment['vitals']['bmi']} ({assessment['classifications']['bmi_class']})\",\n",
    "        f\"  BP: {assessment['vitals']['bp']} ({assessment['classifications']['bp_class']})\",\n",
    "        f\"  Risk Factors: {', '.join(assessment['risk_factors']) or 'None'}\",\n",
    "        f\"  Recommendation: {assessment['recommendation']}\",\n",
    "    ]\n",
    "    return '\\n'.join(lines)\n",
    "\n",
    "def generate_batch_report(patients):\n",
    "    \"\"\"Generate health report for multiple patients.\"\"\"\n",
    "    report_lines = ['\\n' + '=' * 50]\n",
    "    report_lines.append('PATIENT HEALTH ASSESSMENT REPORT')\n",
    "    report_lines.append('=' * 50)\n",
    "    \n",
    "    for patient in patients:\n",
    "        if not is_valid_age(patient['age']):\n",
    "            report_lines.append(f\"\\nWARNING: Invalid age for {patient['name']}\")\n",
    "            continue\n",
    "        \n",
    "        assessment = assess_patient_health(patient)\n",
    "        report_lines.append(format_patient_summary(assessment))\n",
    "    \n",
    "    report_lines.append('\\n' + '=' * 50)\n",
    "    report_lines.append('END OF REPORT')\n",
    "    report_lines.append('=' * 50)\n",
    "    \n",
    "    return '\\n'.join(report_lines)\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 6: EXECUTION\n",
    "# =============================================================================\n",
    "\n",
    "def main():\n",
    "    \"\"\"Main execution function.\"\"\"\n",
    "    print(generate_batch_report(SAMPLE_PATIENTS))\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    main()"
   ]
