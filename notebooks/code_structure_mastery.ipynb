    "print(\"  • No clear organization or sections\")\n",
    "print(\"  • Variables and logic mixed randomly\")\n",
    "print(\"  • Hard to follow the execution flow\")\n",
    "print(\"  • Repeated parsing logic\")\n",
    "print(\"  • No clear separation of concerns\")\n",
    "print()\n",
    "\n",
    "print(\"✅ STRUCTURED CODE:\")\n",
    "print(\"\"\"\n",
    "# =============================================================================\n",
    "# SECTION 1: CONFIGURATION AND DATA\n",
    "# =============================================================================\n",
    "\n",
    "PATIENTS = [\n",
    "    {'name': 'Alice', 'age': 34, 'bp': '120/80'},\n",
    "    {'name': 'Bob', 'age': 45, 'bp': '140/95'},\n",
    "]\n",
    "\n",
    "# =============================================================================\n",
    "# SECTION 2: HELPER FUNCTIONS\n",
    "# =============================================================================\n",
    "\n",
    "def parse_blood_pressure(bp_string):\n",
    "    \"\"\"Parse blood pressure string into systolic and diastolic values.\"\"\"\n",
    "    systolic, diastolic = map(int, bp_string.split('/'))\n",
    "    return systolic, diastolic\n",
    "\n",
    "def classify_blood_pressure(systolic, diastolic):\n",
    "    \"\"\"Classify blood pressure as Normal or High.\"\"\"\n",
    "    if systolic > 140 or diastolic > 90:\n",
    "        return 'High'\n",
    "    return 'Normal'\n",
    "\n",
    "def assess_patient(patient):\n",
    "    \"\"\"Assess a single patient's blood pressure.\"\"\"\n",
    "    systolic, diastolic = parse_blood_pressure(patient['bp'])\n",
    "    classification = classify_blood_pressure(systolic, diastolic)\n",
    "    return {\n",
