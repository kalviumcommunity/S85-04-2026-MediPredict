    "        return float(value)\n",
    "    except (ValueError, TypeError):\n",
    "        return None\n",
    "\n",
    "def parse_age(age_string):\n",
    "    \"\"\"Parse age and validate range.\"\"\"\n",
    "    age = parse_numeric(age_string, 'age')\n",
    "    if age is None or age < 0 or age > 120:\n",
    "        return None\n",
    "    return int(age)\n",
    "\n",
    "def parse_blood_pressure(bp_string):\n",
    "    \"\"\"Parse blood pressure string into components.\"\"\"\n",
    "    try:\n",
    "        systolic, diastolic = map(int, bp_string.split('/'))\n",
    "        return {'systolic': systolic, 'diastolic': diastolic, 'valid': True}\n",
